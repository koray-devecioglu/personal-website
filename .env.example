# Copy to `.env.local` for local work. The `.env*` family is git-ignored
# (except this example file). Only `PUBLIC_*` prefixed values end up in
# the client bundle — everything else stays build-time only.

# Cloudflare Web Analytics site token. Set this on the Cloudflare Pages
# production environment to enable the cookieless analytics beacon.
# Leave unset on dev + branch-preview deployments so previews never
# pollute the live dashboard. Token format: 32 lowercase hex chars.
# PUBLIC_CF_ANALYTICS_TOKEN=

# Override the canonical site URL. Defaults to https://koraydevecioglu.com
# in `astro.config.mjs`. Useful for one-off preview builds where you
# want absolute URLs to resolve to a different host.
# ASTRO_SITE=https://koraydevecioglu.com
