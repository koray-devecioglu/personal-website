---
/**
 * PageLayout — standalone page shell for the indie-web set
 * (`/now`, `/uses`, `/colophon`, `/reading`).
 *
 * Pages are _not_ posts: no type badge, no tags, no reading time,
 * no series banner, no TOC rail. What they need is a proper title,
 * a one-line lead, a last-updated stamp, and the same prose styles
 * that power the blog so a markdown file stays authorable.
 *
 * The route is thin: load an entry from the `pages` collection, hand
 * it here, render `<Content />` inside the slot. No other plumbing.
 */
import type { CollectionEntry } from "astro:content";

import BaseLayout from "./BaseLayout.astro";
import { pageSeo } from "../lib/seo";
import { formatPostDate, isoDate } from "../lib/posts";

interface Props {
  page: CollectionEntry<"pages">;
}

const { page } = Astro.props;
const { title, description, updated, noindex } = page.data;

const seo = pageSeo({
  title,
  description,
  path: `/${page.id}`,
  noindex,
});
---

<BaseLayout seo={seo}>
  <article class="page">
    <header class="page__header">
      <h1 class="page__title">{title}</h1>
      <p class="page__lead">{description}</p>
      <p class="page__meta">
        <span class="page__label">Updated</span>
        <time datetime={isoDate(updated)}>{formatPostDate(updated)}</time>
      </p>
    </header>

    <div class="prose page__prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .page {
    max-width: var(--content-narrow);
    margin-inline: auto;
    padding-block: var(--space-12) var(--space-16);
    padding-inline: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .page__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    border-bottom: 1px solid var(--rule);
    padding-block-end: var(--space-6);
  }
  .page__title {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-weight: 500;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    margin: 0;
  }
  .page__lead {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--fg-muted);
    margin: 0;
    max-width: 60ch;
  }
  .page__meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-subtle);
    margin: 0;
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
  }
  .page__label {
    color: var(--fg-muted);
  }
  .page__prose {
    max-width: none;
  }
</style>
