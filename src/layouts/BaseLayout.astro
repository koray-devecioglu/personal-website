---
/**
 * BaseLayout — the skeleton that every page renders inside.
 *
 * Owns:
 *   - <html lang>, <head> meta (title, description, OG, canonical, feeds)
 *   - Global stylesheet import (fonts, tokens, prose, @theme, base elements)
 *   - Preload of the critical Fraunces subset (prevents FOUT on LCP text)
 *   - Initial theme application (no flash) — reads localStorage and sets
 *     data-theme before first paint; absent value falls through to
 *     prefers-color-scheme via the CSS rules in tokens.css
 *   - View Transitions (Astro's ClientRouter) for cross-page crossfades
 *     on supporting browsers; degrades to a hard navigation elsewhere.
 *   - Skip-link, Header, Footer
 *
 * Takes a pre-built `seo` payload from `lib/seo.ts` — every page that
 * cares about metadata goes through `pageSeo()` so the tags stay
 * consistent without copy-pasted <meta> blocks.
 */
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

import { SITE } from "../data/links";
import { pageSeo, type SeoInput, type SeoOutput } from "../lib/seo";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  /** Pre-built SEO payload. Preferred — goes straight to the head. */
  seo?: SeoOutput;
  /** Or hand in SeoInput and let the layout run pageSeo(). */
  seoInput?: Omit<SeoInput, "path"> & { path?: string };
  /** Legacy single-prop for pages that predate the seo payload. */
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
}

const props = Astro.props;
const defaultPath = Astro.url.pathname;

const seo: SeoOutput =
  props.seo ??
  pageSeo({
    title: props.title ?? SITE.name,
    description: props.description,
    canonical: props.canonical,
    noindex: props.noindex,
    ...props.seoInput,
    path: props.seoInput?.path ?? defaultPath,
  });

// Cloudflare Web Analytics — cookieless, aggregate, no consent banner.
// Token lives in PUBLIC_CF_ANALYTICS_TOKEN so Vite exposes it to the
// client bundle at build time. Absent in dev + preview by design: we
// only ship the beacon when the canonical deploy sets the var, so
// branch previews and local runs stay out of the stats.
//
// Rendered via set:html on a Fragment so Astro's script hoister leaves
// the external beacon alone (it would otherwise try to bundle the
// Cloudflare CDN URL into our own JS pipeline). `defer` means it never
// blocks first paint. Token is a 32-char hex string — safe to
// interpolate into a JSON data attribute without escaping.
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
const cfAnalyticsSnippet = cfAnalyticsToken
  ? `<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "${cfAnalyticsToken}"}'></script>`
  : "";
---

<!doctype html>
<html lang={SITE.locale} data-pagefind-ignore={seo.noindex ? "all" : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />
    {seo.noindex && <meta name="robots" content="noindex, follow" />}

    <meta property="og:type" content={seo.type} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:image" content={seo.ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.ogImage} />

    {
      seo.type === "article" && seo.published && (
        <meta property="article:published_time" content={seo.published} />
      )
    }
    {
      seo.type === "article" && seo.updated && (
        <meta property="article:modified_time" content={seo.updated} />
      )
    }
    {
      seo.type === "article" &&
        seo.tags.map((tag) => <meta property="article:tag" content={tag} />)
    }

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="color-scheme" content="light dark" />

    {/* Feed autodiscovery — lets readers' aggregators find the stream. */}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.name}
      href="/rss.xml"
    />
    <link
      rel="alternate"
      type="application/feed+json"
      title={SITE.name}
      href="/feed.json"
    />

    {
      /*
      Preload the critical serif cut. Fraunces carries H1 + body, so this
      directly affects LCP. Latin-ext, italic, Inter, and JetBrains Mono
      are intentionally not preloaded — we accept a second-paint swap on
      the secondary families to keep the network budget tight.
    */
    }
    <link
      rel="preload"
      href="/fonts/fraunces-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    {
      /*
      Apply the persisted theme before first paint to avoid a flash of the
      wrong theme. Three states: "light", "dark", "system". When the value
      is "system" (or absent / invalid), we leave data-theme unset and let
      prefers-color-scheme decide via tokens.css. Inline by design — tiny,
      runs once, must beat first paint.
    */
    }
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          if (stored === "dark" || stored === "light") {
            document.documentElement.dataset.theme = stored;
          }
        } catch (_) {
          /* localStorage unavailable — fall through to prefers-color-scheme */
        }
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" data-pagefind-body>
      <slot />
    </main>
    <Footer />

    {cfAnalyticsSnippet && <Fragment set:html={cfAnalyticsSnippet} />}

    <style>
      body {
        min-height: 100vh;
        display: grid;
        grid-template-rows: auto 1fr auto;
      }
      .skip-link {
        position: absolute;
        left: 0;
        top: -64px;
        padding: 8px 16px;
        background: var(--bg-elevated);
        color: var(--fg);
        border: 1px solid var(--rule-strong);
        text-decoration: none;
        font-family: var(--font-sans);
        font-size: var(--text-sm);
        transition: top var(--motion-standard) var(--ease-out);
        z-index: 100;
      }
      .skip-link:focus-visible {
        top: 8px;
      }
    </style>
  </body>
</html>
