---
/**
 * CommandPalette — ⌘K / Ctrl+K quick-nav and search.
 *
 * Shape:
 *   - Built-in static index (jump targets, every post, every tag, every
 *     series, handful of actions) is injected as JSON at build time.
 *   - Vanilla TS runs the modal, keyboard nav, focus trap, scoring.
 *   - Pagefind (production only) is imported lazily the first time the
 *     user types. Content matches merge in as a separate section; when
 *     Pagefind isn't present (dev, or pre-build) the palette still
 *     works against the static index.
 *
 * Accessibility:
 *   - Uses a native <dialog> with role=dialog + aria-modal — the browser
 *     handles the focus trap and Escape-to-close.
 *   - The results list has role=listbox; items have role=option; the
 *     input carries aria-controls + aria-activedescendant so screen
 *     readers track the highlight as the user arrows through.
 *
 * The island ships zero dependencies of its own. Pagefind's client
 * runtime (~40 KB gzipped) only downloads after a keypress.
 */
import { buildPaletteIndex } from "../../lib/palette-index";

const index = await buildPaletteIndex();

const GROUP_ORDER = ["jump", "posts", "tags", "series", "actions"] as const;
const GROUP_LABELS: Record<(typeof GROUP_ORDER)[number], string> = {
  jump: "Jump",
  posts: "Posts",
  tags: "Tags",
  series: "Series",
  actions: "Actions",
};

// Tight inline blob: keeps the initial HTML small, and the client script
// parses it without an extra network round-trip.
const paletteData = JSON.stringify({
  items: index.items,
  groups: index.groups,
});
---

<button
  type="button"
  class="palette-trigger"
  data-palette-trigger
  aria-haspopup="dialog"
  aria-controls="palette-dialog"
  aria-label="Open command palette"
>
  <svg
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    focusable="false"
    width="14"
    height="14"
  >
    <circle cx="11" cy="11" r="7"></circle>
    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
  </svg>
  <span class="palette-trigger__label">Search</span>
  <span class="palette-trigger__hint"><kbd>⌘</kbd><kbd>K</kbd></span>
</button>

<dialog
  id="palette-dialog"
  class="palette-dialog"
  data-palette
  aria-label="Command palette"
>
  <div class="palette">
    <div class="palette__search">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        focusable="false"
        width="18"
        height="18"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        type="search"
        class="palette__input"
        data-palette-input
        placeholder="Search posts, tags, pages…"
        aria-label="Search the site"
        aria-controls="palette-list"
        aria-activedescendant=""
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
      />
      <kbd class="palette__escape">Esc</kbd>
    </div>

    <ul
      id="palette-list"
      class="palette__list"
      role="listbox"
      data-palette-list
      aria-label="Results"
    >
    </ul>

    <p class="palette__empty" data-palette-empty hidden>
      Nothing matches <span class="palette__empty-query" data-palette-empty-query
      ></span>.
    </p>

    <footer class="palette__footer">
      <span class="palette__hint">
        <kbd>↑</kbd><kbd>↓</kbd> navigate
      </span>
      <span class="palette__hint">
        <kbd>↵</kbd> select
      </span>
      <span class="palette__hint">
        <kbd>Esc</kbd> close
      </span>
    </footer>
  </div>
</dialog>

<script is:inline type="application/json" data-palette-index set:html={paletteData} />
<script
  is:inline
  type="application/json"
  data-palette-group-order
  set:html={JSON.stringify(GROUP_ORDER)}
/>
<script
  is:inline
  type="application/json"
  data-palette-group-labels
  set:html={JSON.stringify(GROUP_LABELS)}
/>

<script>
  type PaletteKind = "jump" | "post" | "tag" | "series" | "action";

  interface PaletteItem {
    id: string;
    kind: PaletteKind;
    title: string;
    subtitle?: string;
    href?: string;
    action?: string;
    hint?: string;
    keywords?: string[];
    external?: boolean;
  }

  interface PaletteIndex {
    items: PaletteItem[];
    groups: Record<"jump" | "posts" | "tags" | "series" | "actions", string[]>;
  }

  // Pagefind's public API surface. Typed loosely — the runtime is
  // dynamic-imported and its bundle ships without declarations.
  interface PagefindResult {
    id: string;
    data(): Promise<{
      url: string;
      meta: { title?: string };
      excerpt: string;
    }>;
  }
  interface PagefindSearch {
    results: PagefindResult[];
  }
  interface PagefindAPI {
    search(q: string): Promise<PagefindSearch>;
  }

  type GroupKey = "jump" | "posts" | "tags" | "series" | "actions";

  const GROUP_KIND: Record<PaletteKind, GroupKey> = {
    jump: "jump",
    post: "posts",
    tag: "tags",
    series: "series",
    action: "actions",
  };

  function normalise(s: string): string {
    return s
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .toLowerCase()
      .replace(/\s+/g, " ");
  }

  function haystackFor(item: PaletteItem): string {
    return normalise(
      [item.title, item.subtitle ?? "", ...(item.keywords ?? [])].join(" "),
    );
  }

  function subsequenceScore(source: string, query: string): number | null {
    let si = 0;
    let score = 0;
    let prevMatch = -2;
    for (let qi = 0; qi < query.length; qi++) {
      const qch = query[qi]!;
      let found = -1;
      while (si < source.length) {
        if (source[si] === qch) {
          found = si;
          break;
        }
        si++;
      }
      if (found === -1) return null;
      const gap = found - prevMatch - 1;
      score += Math.max(1, 12 - gap);
      prevMatch = found;
      si++;
    }
    return score;
  }

  function matchScore(item: PaletteItem, rawQuery: string): number | null {
    const q = normalise(rawQuery).trim();
    if (!q) return 0;
    const titleNorm = normalise(item.title);
    const haystack = haystackFor(item);
    if (titleNorm.startsWith(q)) return 1000 - q.length;
    const tokens = haystack.split(/\s+/);
    if (tokens.some((t) => t.startsWith(q))) return 500 - q.length;
    if (haystack.includes(q)) return 250;
    const sub = subsequenceScore(titleNorm, q);
    if (sub === null) return null;
    return sub;
  }

  function searchIndex(
    items: readonly PaletteItem[],
    query: string,
    limit = 40,
  ): PaletteItem[] {
    if (!query.trim()) return items.slice(0, limit);
    const scored: { item: PaletteItem; score: number }[] = [];
    for (const item of items) {
      const score = matchScore(item, query);
      if (score === null) continue;
      scored.push({ item, score });
    }
    scored.sort((a, b) => b.score - a.score);
    return scored.slice(0, limit).map((s) => s.item);
  }

  function readJsonScript<T>(selector: string): T {
    const el = document.querySelector(selector);
    if (!el) throw new Error(`palette: missing data blob ${selector}`);
    return JSON.parse(el.textContent ?? "null") as T;
  }

  function init() {
    const dialogEl = document.querySelector<HTMLDialogElement>("[data-palette]");
    const inputEl = document.querySelector<HTMLInputElement>("[data-palette-input]");
    const listEl = document.querySelector<HTMLUListElement>("[data-palette-list]");
    const emptyElRaw = document.querySelector<HTMLElement>("[data-palette-empty]");
    const emptyQRaw = document.querySelector<HTMLElement>("[data-palette-empty-query]");
    if (!dialogEl || !inputEl || !listEl || !emptyElRaw || !emptyQRaw) return;
    // Narrowed aliases. Closures defined below inherit the non-null
    // types from these `const`s; without them TS widens back to `X | null`.
    const dialog = dialogEl;
    const input = inputEl;
    const list = listEl;
    const emptyEl = emptyElRaw;
    const emptyQ = emptyQRaw;

    const index = readJsonScript<PaletteIndex>("[data-palette-index]");
    const groupOrder = readJsonScript<GroupKey[]>("[data-palette-group-order]");
    const groupLabels = readJsonScript<Record<GroupKey, string>>(
      "[data-palette-group-labels]",
    );

    const triggers = document.querySelectorAll<HTMLButtonElement>(
      "[data-palette-trigger]",
    );

    let activeId = "";
    // Pagefind cached once loaded. Kept as null until the first attempt
    // succeeds so retries don't swallow a failed import silently.
    let pagefind: PagefindAPI | null = null;
    let pagefindAttempted = false;
    let pagefindDisabled = false;

    async function maybeLoadPagefind(): Promise<void> {
      if (pagefindAttempted || pagefindDisabled) return;
      pagefindAttempted = true;
      try {
        // Rollup would try to resolve this at build time if the path were
        // a static literal — the file only appears in `dist/` after
        // `pagefind --site dist` runs, so we opacify the URL behind a
        // variable and tag it `@vite-ignore` for dev builds.
        const pagefindUrl = `${window.location.origin}/pagefind/pagefind.js`;
        const mod: unknown = await import(/* @vite-ignore */ pagefindUrl);
        const api = mod as PagefindAPI;
        if (api && typeof api.search === "function") {
          pagefind = api;
        } else {
          pagefindDisabled = true;
        }
      } catch {
        // In dev — and any build that hasn't run `pagefind --site dist`
        // — the script doesn't exist. That's fine; the static index
        // still covers the whole palette.
        pagefindDisabled = true;
      }
    }

    function open() {
      if (dialog.open) return;
      dialog.showModal();
      render(input.value);
      input.focus();
      input.select();
    }

    function close() {
      if (!dialog.open) return;
      dialog.close();
    }

    function render(query: string) {
      const staticHits = searchIndex(index.items, query);
      const grouped = new Map<GroupKey, PaletteItem[]>();
      for (const hit of staticHits) {
        const key = GROUP_KIND[hit.kind];
        const bucket = grouped.get(key) ?? [];
        bucket.push(hit);
        grouped.set(key, bucket);
      }

      // Render synchronously against the static index; Pagefind is
      // layered on by mutating the posts group after its promise lands.
      renderGroups(query, grouped);

      if (query.trim()) {
        void augmentWithPagefind(query, grouped);
      }
    }

    async function augmentWithPagefind(
      query: string,
      grouped: Map<GroupKey, PaletteItem[]>,
    ): Promise<void> {
      await maybeLoadPagefind();
      if (!pagefind) return;
      let search: PagefindSearch;
      try {
        search = await pagefind.search(query);
      } catch {
        return;
      }
      // The input may have changed while we awaited — only apply if
      // the live query still matches.
      if (input.value.trim() !== query.trim()) return;
      const existing = new Set((grouped.get("posts") ?? []).map((p) => p.href ?? ""));
      const extras: PaletteItem[] = [];
      const data = await Promise.all(
        search.results.slice(0, 5).map((r) => r.data().catch(() => null)),
      );
      for (const d of data) {
        if (!d) continue;
        const url = d.url.replace(/\/$/, "") || "/";
        if (existing.has(url)) continue;
        extras.push({
          id: `pagefind:${url}`,
          kind: "post",
          title: d.meta.title ?? url,
          subtitle: "content match",
          href: url,
        });
      }
      if (!extras.length) return;
      const current = grouped.get("posts") ?? [];
      grouped.set("posts", [...current, ...extras]);
      renderGroups(query, grouped);
    }

    function renderGroups(query: string, grouped: Map<GroupKey, PaletteItem[]>): void {
      list.innerHTML = "";
      let total = 0;
      let firstId = "";

      for (const group of groupOrder) {
        const items = grouped.get(group);
        if (!items || items.length === 0) continue;

        const heading = document.createElement("li");
        heading.className = "palette__group";
        heading.setAttribute("role", "presentation");
        heading.textContent = groupLabels[group];
        list.appendChild(heading);

        for (const item of items) {
          const li = document.createElement("li");
          li.className = "palette__item";
          li.id = `palette-item-${cssEscape(item.id)}`;
          li.setAttribute("role", "option");
          li.dataset.paletteItem = item.id;
          li.dataset.paletteKind = item.kind;
          if (item.href) li.dataset.paletteHref = item.href;
          if (item.action) li.dataset.paletteAction = item.action;
          if (item.external) li.dataset.paletteExternal = "true";

          const title = document.createElement("span");
          title.className = "palette__item-title";
          title.textContent = item.title;
          li.appendChild(title);

          if (item.subtitle) {
            const sub = document.createElement("span");
            sub.className = "palette__item-sub";
            sub.textContent = item.subtitle;
            li.appendChild(sub);
          }

          if (item.hint) {
            const hint = document.createElement("kbd");
            hint.className = "palette__item-hint";
            hint.textContent = item.hint;
            li.appendChild(hint);
          }

          list.appendChild(li);
          if (!firstId) firstId = li.id;
          total++;
        }
      }

      if (total === 0 && query.trim()) {
        emptyEl.hidden = false;
        emptyQ.textContent = `"${query.trim()}"`;
      } else {
        emptyEl.hidden = true;
      }

      setActive(firstId);
    }

    function setActive(id: string): void {
      if (activeId) {
        const prev = document.getElementById(activeId);
        if (prev) prev.setAttribute("aria-selected", "false");
      }
      activeId = id;
      input.setAttribute("aria-activedescendant", id);
      if (!id) return;
      const curr = document.getElementById(id);
      if (!curr) return;
      curr.setAttribute("aria-selected", "true");
      // Keep the active option inside the scroll viewport.
      curr.scrollIntoView({ block: "nearest" });
    }

    function moveActive(direction: 1 | -1): void {
      const items = Array.from(
        list.querySelectorAll<HTMLElement>("[data-palette-item]"),
      );
      if (!items.length) return;
      const idx = items.findIndex((el) => el.id === activeId);
      const nextIdx = (idx + direction + items.length) % items.length;
      const next = items[nextIdx];
      if (next) setActive(next.id);
    }

    function activateCurrent(): void {
      if (!activeId) return;
      const el = document.getElementById(activeId);
      if (!el) return;
      executeItem(el);
    }

    function executeItem(el: HTMLElement): void {
      const action = el.dataset.paletteAction;
      const href = el.dataset.paletteHref;
      const external = el.dataset.paletteExternal === "true";
      if (action) {
        close();
        handleAction(action);
        return;
      }
      if (href) {
        close();
        if (external) {
          window.open(href, "_blank", "noopener,noreferrer");
        } else {
          window.location.href = href;
        }
      }
    }

    function handleAction(action: string): void {
      switch (action) {
        case "toggle-theme": {
          const root = document.documentElement;
          const current = root.dataset.theme;
          const next =
            current === "dark" ? "light" : current === "light" ? "dark" : "dark";
          root.dataset.theme = next;
          try {
            localStorage.setItem("theme", next);
          } catch {
            /* storage unavailable — the runtime toggle still applies */
          }
          // Let any other theme-aware island pick up the change.
          document.dispatchEvent(
            new CustomEvent("theme-change", { detail: { theme: next } }),
          );
          break;
        }
        case "copy-url": {
          if (navigator.clipboard) {
            void navigator.clipboard.writeText(window.location.href);
          }
          break;
        }
      }
    }

    function cssEscape(s: string): string {
      return s.replace(/[^a-zA-Z0-9_-]/g, (c) => `_${c.charCodeAt(0).toString(16)}`);
    }

    function isTypingInField(target: EventTarget | null): boolean {
      if (!(target instanceof HTMLElement)) return false;
      const tag = target.tagName;
      return (
        tag === "INPUT" ||
        tag === "TEXTAREA" ||
        target.isContentEditable ||
        tag === "SELECT"
      );
    }

    // ── Wire events ─────────────────────────────────────────────────

    for (const trigger of triggers) {
      trigger.addEventListener("click", () => open());
    }

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
        e.preventDefault();
        if (dialog.open) close();
        else open();
        return;
      }
      if (e.key === "/" && !isTypingInField(e.target) && !dialog.open) {
        e.preventDefault();
        open();
      }
    });

    input.addEventListener("input", () => render(input.value));

    input.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        moveActive(1);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        moveActive(-1);
      } else if (e.key === "Enter") {
        e.preventDefault();
        activateCurrent();
      }
    });

    list.addEventListener("click", (e) => {
      const target = (e.target as HTMLElement | null)?.closest<HTMLElement>(
        "[data-palette-item]",
      );
      if (target) executeItem(target);
    });

    list.addEventListener("mousemove", (e) => {
      const target = (e.target as HTMLElement | null)?.closest<HTMLElement>(
        "[data-palette-item]",
      );
      if (target && target.id !== activeId) setActive(target.id);
    });

    // Clicking the backdrop closes. The <dialog> element dispatches a
    // click whose target is the dialog itself when the backdrop is hit.
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) close();
    });

    dialog.addEventListener("close", () => {
      // Return focus to the trigger that opened the palette, if any.
      if (document.activeElement === document.body && triggers[0]) {
        triggers[0].focus();
      }
    });

    // Intentionally skip an initial render(""). Populating the list on
    // mount would inject all items into every page's DOM, which breaks
    // strict-mode locators in tests and bloats the accessibility tree.
    // open() calls render() on demand — the cost is one frame on first
    // open, invisible in practice.
  }

  // Astro's ClientRouter re-runs the module on every SPA navigation.
  // Guard against double-init by keying off a marker on <html>.
  function boot(): void {
    if (document.documentElement.dataset.paletteReady === "true") return;
    document.documentElement.dataset.paletteReady = "true";
    init();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot, { once: true });
  } else {
    boot();
  }

  document.addEventListener("astro:after-swap", () => {
    document.documentElement.dataset.paletteReady = "";
    boot();
  });
</script>

<style>
  /* ── Trigger (header button) ──────────────────────────────────────── */
  .palette-trigger {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 6px var(--space-2) 6px var(--space-3);
    border: 1px solid var(--rule);
    border-radius: var(--radius-md);
    background: var(--bg-elevated);
    color: var(--fg-muted);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    cursor: pointer;
    transition:
      border-color var(--motion-micro) var(--ease-out),
      color var(--motion-micro) var(--ease-out);
  }
  .palette-trigger:hover,
  .palette-trigger:focus-visible {
    color: var(--fg);
    border-color: var(--rule-strong);
  }
  .palette-trigger__label {
    display: none;
  }
  .palette-trigger__hint {
    display: none;
    gap: 2px;
    align-items: center;
  }
  .palette-trigger__hint kbd {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 1px 5px;
    border: 1px solid var(--rule);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--fg-muted);
  }
  @media (min-width: 720px) {
    .palette-trigger__label,
    .palette-trigger__hint {
      display: inline-flex;
    }
    .palette-trigger {
      padding-right: var(--space-3);
    }
  }

  /* ── Dialog / backdrop ────────────────────────────────────────────── */
  .palette-dialog {
    padding: 0;
    border: none;
    background: transparent;
    color: inherit;
    max-width: min(640px, calc(100vw - 2 * var(--space-6)));
    width: 100%;
    margin: 12vh auto auto;
  }
  .palette-dialog::backdrop {
    background: var(--scrim);
    backdrop-filter: blur(3px);
  }
  .palette-dialog[open] {
    animation: palette-in var(--motion-standard) var(--ease-out);
  }
  @keyframes palette-in {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .palette-dialog[open] {
      animation: none;
    }
  }

  .palette {
    display: flex;
    flex-direction: column;
    background: var(--bg-elevated);
    border: 1px solid var(--rule-strong);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  /* ── Search row ───────────────────────────────────────────────────── */
  .palette__search {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-4);
    border-bottom: 1px solid var(--rule);
    color: var(--fg-muted);
  }
  .palette__input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    color: var(--fg);
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    line-height: 1;
  }
  .palette__input::placeholder {
    color: var(--fg-subtle);
  }
  .palette__escape {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 2px 6px;
    border: 1px solid var(--rule);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--fg-muted);
  }

  /* ── List ─────────────────────────────────────────────────────────── */
  .palette__list {
    list-style: none;
    margin: 0;
    padding: var(--space-2) 0;
    max-height: min(60vh, 480px);
    overflow-y: auto;
  }
  .palette__group {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-subtle);
    padding: var(--space-3) var(--space-5) var(--space-1);
    user-select: none;
  }
  .palette__item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2px var(--space-3);
    align-items: baseline;
    padding: var(--space-2) var(--space-5);
    cursor: pointer;
    color: var(--fg);
    border-left: 2px solid transparent;
  }
  .palette__item[aria-selected="true"] {
    background: var(--accent-subtle);
    border-left-color: var(--accent);
    color: var(--fg);
  }
  .palette__item-title {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: 1.3;
    grid-column: 1;
    grid-row: 1;
