---
/**
 * Footer — site chrome, bottom of every page.
 *
 * Layout (stacked on narrow viewports, two-column on wide):
 *   top row — © + license (left), social + mailto (right)
 *   bottom row — colophon stub (links to /colophon once it lands in M6)
 *
 * Social icons are raw inline SVG (GitHub / LinkedIn / Instagram). For
 * three glyphs, an icon library would earn its keep in dependency cost
 * alone. The LinkedIn / Instagram entries still render even when marked
 * `placeholder: true` in src/data/links.ts — the URL is syntactically
 * valid and swaps in place when Koray hands over his real profile URLs.
 */
import { SITE, SOCIAL } from "../../data/links";
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <div class="legal">
        <p class="legal__copy">{SITE.copyright}</p>
        <p class="legal__license">
          Prose licensed under <a
            href="https://creativecommons.org/licenses/by/4.0/"
            rel="noopener noreferrer license"
            target="_blank">CC BY 4.0</a
          > · code under <a
            href="https://opensource.org/license/mit"
            rel="noopener noreferrer license"
            target="_blank">MIT</a
          >
        </p>
      </div>

      <nav class="site-footer__meta" aria-label="Contact and social">
        <ul class="social">
          <li>
            <a
              href={SOCIAL.github.url}
              rel="me noopener noreferrer"
              target="_blank"
              aria-label={`${SOCIAL.github.label} profile`}
            >
              <svg
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
                focusable="false"
                width="18"
                height="18"
              >
                <path
                  d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.8.1-.8.1-.8 1.2.1 1.8 1.3 1.8 1.3 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.3 0 0 1-.3 3.3 1.3a11.5 11.5 0 0 1 6 0c2.3-1.6 3.3-1.3 3.3-1.3.7 1.7.2 3 .1 3.3.8.8 1.3 1.9 1.3 3.2 0 4.7-2.8 5.6-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .5Z"
                ></path>
              </svg>
            </a>
          </li>
          <li>
            <a
              href={SOCIAL.linkedin.url}
              rel="me noopener noreferrer"
              target="_blank"
              aria-label={`${SOCIAL.linkedin.label} profile`}
            >
              <svg
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
                focusable="false"
                width="18"
                height="18"
              >
                <path
                  d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.95v5.66H9.37V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.61 0 4.28 2.37 4.28 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45C23.2 24 24 23.23 24 22.28V1.72C24 .77 23.2 0 22.22 0Z"
                ></path>
              </svg>
            </a>
          </li>
          <li>
            <a
              href={SOCIAL.instagram.url}
              rel="me noopener noreferrer"
              target="_blank"
              aria-label={`${SOCIAL.instagram.label} profile`}
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                focusable="false"
                width="18"
                height="18"
              >
                <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                <circle cx="12" cy="12" r="4"></circle>
                <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"
                ></circle>
              </svg>
            </a>
          </li>
          <li class="mailto">
            <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </li>
        </ul>
      </nav>
    </div>

    <p class="colophon">
      Built with <a href="https://astro.build" rel="noopener noreferrer" target="_blank"
        >Astro</a
      > · hand-set typography · <span class="colophon__stub"
        >/colophon coming in M6</span
      >
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--rule);
    margin-top: var(--space-24);
    background: var(--bg);
    color: var(--fg-muted);
  }
  .site-footer__inner {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .site-footer__top {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    justify-content: space-between;
    align-items: flex-start;
  }
  @media (min-width: 640px) {
    .site-footer__top {
      flex-direction: row;
      align-items: center;
    }
  }

  .legal {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }
  .legal__copy {
    margin: 0;
    color: var(--fg);
  }
  .legal__license {
    margin: 0;
    color: var(--fg-subtle);
  }
  .legal a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule-strong);
  }
  .legal a:hover {
    color: var(--accent-strong);
    text-decoration-color: var(--accent);
  }

  .social {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--fg-muted);
    border-radius: var(--radius-md);
    transition:
      color var(--motion-micro) var(--ease-out),
      background-color var(--motion-micro) var(--ease-out);
  }
  .social a:hover {
    color: var(--accent-strong);
    background: var(--bg-elevated);
  }
  .social .mailto a {
    width: auto;
    padding: 6px var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-decoration: none;
    color: var(--fg-muted);
    border: 1px solid var(--rule);
  }
  .social .mailto a:hover {
    color: var(--accent-strong);
    border-color: var(--accent);
  }

  .colophon {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-subtle);
  }
  .colophon a {
    color: var(--fg-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule-strong);
  }
  .colophon a:hover {
    color: var(--accent-strong);
  }
  .colophon__stub {
    opacity: 0.7;
  }
</style>
