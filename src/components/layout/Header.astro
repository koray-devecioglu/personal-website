---
/**
 * Header — site chrome, top of every page.
 *
 * Layout:
 *   - Wordmark on the left (links home).
 *   - Primary nav: Posts, Tags, Series. CV lands in M5, About/Uses in M6.
 *   - Theme toggle on the right.
 *
 * Nav items carry `aria-current="page"` when the current URL matches,
 * so the active item reads as such for screen readers and can be
 * styled without JS.
 */
import { SITE } from "../../data/links";
import ThemeToggle from "../islands/ThemeToggle.astro";
import { t } from "../../lib/i18n";

// Nav hrefs match the site's `trailingSlash: "never"` config — this
// avoids dev-mode 404s on `/posts/` style links (the dev server only
// redirects in prod builds). `isActive` still normalises defensively
// in case some other caller hands us a path with a slash.
const trimSlash = (p: string): string => p.replace(/\/$/, "") || "/";
const pathname = trimSlash(Astro.url.pathname);

const NAV = [
  { href: "/posts", label: t("nav.posts") },
  { href: "/tags", label: t("nav.tags") },
  { href: "/series", label: t("nav.series") },
  { href: "/cv", label: t("nav.cv") },
];

function isActive(href: string): boolean {
  const target = trimSlash(href);
  if (target === "/") return pathname === "/";
  return pathname === target || pathname.startsWith(`${target}/`);
}
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="wordmark" aria-label={`${SITE.name} — home`}>
      <span class="wordmark__name">{SITE.name}</span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {
          NAV.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={["site-nav__link", { "is-active": isActive(item.href) }]}
                aria-current={isActive(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="site-header__actions">
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: var(--bg);
  }
  .site-header__inner {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--space-4) var(--space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }
  .wordmark {
    color: var(--fg);
    text-decoration: none;
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 500;
    letter-spacing: var(--tracking-tight);
    line-height: 1;
  }
  .wordmark:hover .wordmark__name {
    color: var(--accent-strong);
  }
  .wordmark__name {
    transition: color var(--motion-micro) var(--ease-out);
  }
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .site-nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }
  .site-nav__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-6);
  }
  .site-nav__link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-muted);
    text-decoration: none;
    padding-block: var(--space-1);
    border-bottom: 1px solid transparent;
    transition:
      color var(--motion-micro) var(--ease-out),
      border-color var(--motion-micro) var(--ease-out);
  }
  .site-nav__link:hover,
  .site-nav__link:focus-visible {
    color: var(--fg);
  }
  .site-nav__link.is-active {
    color: var(--fg);
    border-bottom-color: var(--accent);
  }

  /* Narrow: collapse nav to wrap under wordmark. No hamburger in M4 — the
     list is short enough that wrapping reads cleanly. */
  @media (max-width: 640px) {
    .site-header__inner {
      flex-wrap: wrap;
    }
    .site-nav {
      order: 3;
      width: 100%;
      justify-content: flex-start;
    }
    .site-nav__list {
      gap: var(--space-4);
    }
  }
</style>
