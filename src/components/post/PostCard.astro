---
/**
 * PostCard — one entry in a feed list.
 *
 * Used on `/`, `/posts`, `/tags/[slug]`, and `/series/[slug]`. Renders
 * as a horizontal row with a hover treatment that lifts the title but
 * leaves the card boundary quiet — cards should feel like editorial
 * index entries, not buttons.
 *
 * Accepts a pre-computed `readingMinutes` so the caller controls the
 * cost of reading-time computation (one read of `render()` per post).
 */
import PostMeta from "./PostMeta.astro";
import { postPath, type ReadablePost } from "../../lib/posts";

interface Props {
  post: ReadablePost;
  readingMinutes?: number;
}

const { post, readingMinutes } = Astro.props;
const { title, description, date, tags } = post.data;
const href = postPath(post);
---

<article class="post-card">
  <a class="post-card__link" href={href}>
    <h2 class="post-card__title">{title}</h2>
    <p class="post-card__dek">{description}</p>
  </a>
  <PostMeta date={date} readingMinutes={readingMinutes} tags={tags} linkTags={true} />
</article>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--rule);
  }
  .post-card:last-child {
    border-bottom: 0;
  }
  .post-card__link {
    color: inherit;
    text-decoration: none;
    display: block;
  }
  .post-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 650;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    font-variation-settings: "opsz" 24;
    margin: 0 0 var(--space-2);
    text-wrap: balance;
    transition: color var(--motion-micro) var(--ease-out);
  }
  .post-card__link:hover .post-card__title,
  .post-card__link:focus-visible .post-card__title {
    color: var(--accent-strong);
  }
  .post-card__dek {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--fg-muted);
    margin: 0;
    max-width: 62ch;
    line-height: var(--leading-normal);
  }
</style>
