---
/**
 * /cv — editorial screen layout for the résumé.
 *
 * Pulls validated content from lib/resume.ts, renders through the
 * shared <CVContent /> component, and wraps it in the standard
 * BaseLayout so nav / footer / theme toggle all work.
 *
 * The print variant lives at /cv/print. The JSON endpoint lives at
 * /cv.json. Links to both are surfaced in the toolbar at the top of
 * this page.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import CVContent from "../components/cv/CVContent.astro";
import { loadResume } from "../lib/resume";
import "../styles/cv.css";

const resume = loadResume();
---

<BaseLayout
  seoInput={{
    title: `${resume.basics.name} — CV`,
    description: resume.basics.summary,
    path: "/cv",
  }}
>
  {
    resume._placeholder && (
      <div class="cv" aria-hidden="false">
        <p class="cv-placeholder-notice">
          <strong>Heads-up:</strong> this CV is still placeholder content. Real
          employers, projects, and dates will land before launch. The typography, print
          stylesheet, and JSON endpoint are all production ready — only the text needs
          to change.
        </p>
      </div>
    )
  }

  <CVContent resume={resume} />

  <div class="cv">
    <nav class="cv-toolbar" aria-label="CV formats">
      <a href="/cv/print">Print-friendly version</a>
      <span class="cv-toolbar__sep" aria-hidden="true">·</span>
      <a href="/cv.json">JSON Resume</a>
    </nav>
  </div>
</BaseLayout>
