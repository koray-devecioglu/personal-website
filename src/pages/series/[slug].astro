---
/**
 * `/series/[slug]` — a single series' ordered posts.
 *
 * Renders the series title + summary, then walks the order[] in the
 * series frontmatter, reusing PostCard.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/post/PostCard.astro";
import { getSeriesBundles, type ReadablePost } from "../../lib/posts";
import { readingTime } from "../../lib/reading-time";
import { pageSeo } from "../../lib/seo";
import { t } from "../../lib/i18n";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const bundles = await getSeriesBundles();
  return bundles.map((bundle) => ({
    params: { slug: bundle.entry.id },
    props: { entry: bundle.entry, posts: bundle.posts },
  }));
}

interface Props {
  entry: CollectionEntry<"series">;
  posts: readonly ReadablePost[];
}

const { entry, posts } = Astro.props;
const readingMinutes = posts.map((post) => readingTime(post.body ?? "").minutes);

const seo = pageSeo({
  title: entry.data.title,
  description: entry.data.summary,
  path: `/series/${entry.id}`,
});
---

<BaseLayout seo={seo}>
  <section class="series-page">
    <header class="series-page__header">
      <p class="series-page__eyebrow">
        <a href="/series">{t("series.title")}</a>
        <span aria-hidden="true">/</span>
        <span>{t("series.page.subtitle", { count: posts.length })}</span>
      </p>
      <h1 class="series-page__title">{entry.data.title}</h1>
      <p class="series-page__summary">{entry.data.summary}</p>
    </header>
    <ol class="series-page__list" start="1">
      {
        posts.map((post, i) => (
          <li>
            <span class="series-page__number" aria-hidden="true">
              {String(i + 1).padStart(2, "0")}
            </span>
            <PostCard post={post} readingMinutes={readingMinutes[i]} />
          </li>
        ))
      }
    </ol>
  </section>
</BaseLayout>

<style>
  .series-page {
    max-width: var(--content-narrow);
    margin-inline: auto;
    padding-block: var(--space-12) var(--space-16);
    padding-inline: var(--space-6);
  }
  .series-page__header {
    margin-block-end: var(--space-8);
  }
  .series-page__eyebrow {
    display: flex;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-muted);
    margin: 0 0 var(--space-2);
  }
  .series-page__eyebrow a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 0.2em;
  }
  .series-page__title {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-variation-settings: "opsz" 48;
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-4);
    text-wrap: balance;
  }
  .series-page__summary {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--fg-muted);
    line-height: var(--leading-snug);
    max-width: 62ch;
    margin: 0;
  }
  .series-page__list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: series-order;
  }
  .series-page__list > li {
    display: grid;
    grid-template-columns: 3ch 1fr;
    gap: var(--space-4);
    align-items: start;
  }
  .series-page__number {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg-subtle);
    letter-spacing: var(--tracking-wider);
    padding-block-start: var(--space-6);
  }
</style>
